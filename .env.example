# ─── Database ─────────────────────────────────────────────────
# Leave empty for SQLite (local dev). Set for PostgreSQL (production).
# Supports: Supabase, Neon, Railway, AWS RDS, any PostgreSQL host.
DATABASE_URL=postgresql://user:password@host:5432/jobcopilot
SQLITE_PATH=./data.db
DATABASE_SSL=true

# ─── Auth ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
